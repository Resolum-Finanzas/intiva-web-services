' Analytics Bounded Context
package "Analytics Bounded Context" #A8A9F7 {

  ' Domain layer
  package "domain" {
    package "algorithms" {
      class FinancialIndicatorAlgorithm {
        +calculate_tcea(loan_parameters, payment_schedule): float
        ' VAN = n∑t=0 (Net Flow of t / (1 + r)^t) [VAN = Sum of (Net Flow of the period / (1 + discount rate of period)^number of periods)]
        +calculate_van(net_flow_list, discount_rate_list, number_of_periods): float
        +calculate_tir(net_flow_list, number_of_periods): float
      }

      class FrenchMethodAlgorithm {
        ' C = P * [(r * (1 + r)^n)) / ((1 + r)^n - 1))]
        +calculate_period_fee(financed_amount, tea, total_number_periods): float
        ' Sd = S * d [Mortgage protection insurance for the period = Financed amount (Start of the period) * Mortgage protection factor]
        +calculate_mortgage_protection_for_period(financed_amount, mortgage_factor): float
        ' In = CIn-1 * r [Period interest = Previous balance * credit interest rate]
        +calculate_interest_for_period(previous_balance, tea, previous_period_interest): float
        ' An = Cn - In [Amortization = Period fee - Period interest]
        +calculate_amortization_for_period(period_fee, interest_of_period): float
        ' CAn = CAn-1 + An [Amortized capital = Previous amortized capital + Amortization of the period] (not so necessary)
        +calculate_amortized_capital_for_period(previous_amortized, amortization_of_period): float
        ' CIn = CIn-1 - An [Period balance = Previous balance - Amortization of the period]
        +calculate_balance_for_period(previous_balance, amortization_of_period): float
        ' Balloon = S * Balloon percentage [Balloon payment = Financed amount (Start of the period) * Balloon payment percentage]
        +calculate_balloon_fee(financed_amount, balloon_payment_percentage): float
      }

      class InsuranceAlgorithm {
        ' TDA = td * 12 [Mortgage protection annual = mortgage protection rate monthly * 12]
        ' d = (TDA * days) / (360) [Mortgage protection factor = (mortgage protection annual * payment frequency in days) / (360)]
        +calculate_mortgage_protection_factor(mortgage_protection_monthly, payment_frequency_in_days): float
        ' n = (TUA * days) / 360 [Vehicular insurance factor = (Vehicular insurance rate * payment frequency in days) / 360]
        +calculate_vehicular_insurance_factor(vehicular_insurance_rate): float
      }

      class GracePeriodAlgorithm {
        ' PG = (S0 * TEM) [Partial Grace Monthly Payment = Financed amount (Start of the period) * Monthly effective rate (convert to TEM from TEA)]
        ' Additional will be needed the months of grace period fo calculation of french method without the months of the grace period
        +calculate_partial_grace_for_monthly_period(financed_amount, tea): float
        ' S1 = S1 * (1 + TEM)^g [New financed amount at the end of the grace period = Financed amount * (1 + Monthly effective rate)^number of months of grace period]
        +calculate_total_grace_period_amount(financed_amount, interest, grace_period_months): float
      }
    }

    package "services" {
      class SmartPurchaseService {
        -financial_indicator_algorithm: FinancialIndicatorAlgorithm
        -french_method_algorithm: FrenchMethodAlgorithm
        -insurance_algorithm: InsuranceAlgorithm
        -grace_period_algorithm: GracePeriodAlgorithm
        +__init__()
        +perform_loan_simulation(loan_parameters): Tuple[LoanParameters, LoanSimulation, PaymentSchedule]
      }
    }

    package "model" {
      ' This class represents the parameters required for a loan simulation
      ' Entered by the user to perform the simulation
      class LoanParameters {
        bank_entity: str
        credit_term_in_months: int
        initial_payment_amount: float
        financed_amount: float
        credit_price: float
        tea_percentage: float
        payment_frequency: str
        balloon_payment_percentage: float
        vehicular_insurance_enabled: bool
        ' This is the TUA
        vehicular_insurance_rate: float
        mortgage_protection_insurance_enabled: boolean
        mortgage_protection_insurance_rate: float
        grace_period_enabled: boolean
        grace_period_type: str
        grace_period_in_months: int
        vehicle_id: str
        user_id: str
      }

      ' This class represents the result of a loan simulation, including the calculated TCEA, VAN, TIR, and the payment schedule
      class LoanSimulation {
        loan_parameters: LoanParameters
        payment_schedule: PaymentSchedule
        tcea_percentage: float
        ballon_payment_amount: float
        van: float
        tir: float
        grace_interest: float
        user_id: str
      }

      ' This class represents the details of each payment period in the loan simulation, including the initial balance, interest amount, amortization amount, tax relief insurance amount, vehicular insurance amount, total payment, final balance, net flow, and whether it is a balloon payment or grace period
      class PaymentPeriod {
        period_number: int
        current_balance: float
        interest_amount: float
        amortization_amount: float
        mortgage_protection_insurance_amount: float
        vehicular_insurance_amount: float
        total_payment: float
        final_balance: float
        net_flow: float
        is_balloon: bool
        is_grace_period: bool
        payment_date: datetime
      }

      ' This class represents the overall payment schedule for the loan simulation, including the total interest, total amortization, total tax relief, total vehicular insurance, total payment, total grace interest, and a list of payment periods
      class PaymentSchedule {
        total_interest: float
        total_amortization: float
        total_mortgage_protection_insurance: float
        total_vehicular_insurance: float
        total_payment: float
        total_grace_interest: float
        periods: List[PaymentPeriods]
      }
    }
  }

  ' Application layer
  package "application" {
    class SmartPurchaseApplicationService {
      -loan_simulation_repository: LoanSimulationRepository
      -loan_parameters_repository: LoanParametersRepository
      -payment_schedule_repository: PaymentScheduleRepository
      -payment_period_repository: PaymentPeriodRepository
      -smart_purchase_service: SmartPurchaseService
      +__init__(db)
      +perform_loan_simulation(loan_parameters): Tuple[LoanParameters, LoanSimulation, PaymentSchedule]
      +get_loan_simulation_by_id(loan_simulation_id): Tuple[LoanParameters, LoanSimulation, PaymentSchedule]
      +get_all_loan_simulations_by_user_id(user_id): List[LoanSimulation]
    }
  }

  ' Infrastructure layer
  package "infrastructure" {
    package "repositories" {
      class LoanParametersRepository {
        -loan_parameters_mysql_repository: LoanParametersMySQLRepository
        +__init__(db)
        +create_loan_parameters(): LoanParameters
        +get_by_loan_simulation_id(loan_simulation_id): Optional[LoanParameters]
      }

      class LoanSimulationRepository {
        -loan_simulation_mysql_repository: LoanSimulationMySQLRepository
        +__init__(db)
        +create_loan_simulation(): LoanSimulation
        +get_by_id(loan_simulation_id): Optional[LoanSimulation]
        +get_all_by_user_id(user_id): List[LoanSimulation]
      }

      class PaymentScheduleRepository {
        -payment_schedule_mysql_repository: PaymentScheduleMySQLRepository
        +__init__(db)
        +create_payment_schedule(): PaymentSchedule
        +get_by_loan_simulation_id(loan_simulation_id): Optional[PaymentSchedule]
      }

      class PaymentPeriodRepository {
        -payment_period_mysql_repository: PaymentPeriodMySQLRepository
        +__init__(db)
        +create_payment_period(): PaymentPeriod
        +get_all_by_payment_schedule_id(payment_schedule_id): List[PaymentPeriod]
      }
    }

    package "persistence" {
      package "model" {
        class LoanParametersModel {
          bank_entity: Mapped[str]
          credit_term_in_months: Mapped[int]
          initial_payment_amount: Mapped[float]
          financed_amount: Mapped[float]
          credit_price: Mapped[float]
          tea_percentage: Mapped[float]
          payment_frequency: Mapped[str]
          balloon_payment_percentage: Mapped[float]
          vehicular_insurance_enabled: Mapped[bool]
          vehicular_insurance_rate: Mapped[float]
          mortgage_protection_insurance_enabled: Mapped[bool]
          mortgage_protection_insurance_rate: Mapped[float]
          grace_period_enabled: Mapped[bool]
          grace_period_type: Mapped[str]
          grace_period_in_months: Mapped[int]
          vehicle_id: Mapped[str]
          user_id: Mapped[str]
        }

        class LoanSimulationModel {
          loan_parameters_id: Mapped[str]
          payment_schedule_id: Mapped[str]
          tcea_percentage: Mapped[float]
          ballon_payment_amount: Mapped[float]
          van: Mapped[float]
          tir: Mapped[float]
          grace_interest: Mapped[float]
          user_id: Mapped[str]
        }

        class PaymentPeriodModel {
          period_number: Mapped[float]
          current_balance: Mapped[float]
          interest_amount: Mapped[float]
          amortization_amount: Mapped[float]
          mortgage_protection_insurance_amount: Mapped[float]
          vehicular_insurance_amount: Mapped[float]
          total_payment: Mapped[float]
          final_balance: Mapped[float]
          net_flow: Mapped[float]
          is_balloon: Mapped[bool]
          is_grace_period: Mapped[bool]
          payment_date: Mapped[datetime]
          payment_schedule_id: Mapped[str]
        }

        class PaymentScheduleModel {
          total_interest: Mapped[float]
          total_amortization: Mapped[float]
          total_mortgage_protection_insurance: Mapped[float]
          total_vehicular_insurance: Mapped[float]
          total_payment: Mapped[float]
          total_grace_interest: Mapped[float]
        }
      }

      package "repositories" {
        class LoanParametersMySQLRepository {
          +__init__(db)
          +to_model(loan_parameters): LoanParametersModel
          +to_entity(loan_parameters_model): LoanParameters
          +get_all_by_user_id(user_id): List[LoanParameters]
        }

        class LoanSimulationMySQLRepository {
          +__init__(db)
          +to_model(loan_simulation): LoanSimulationModel
          +to_entity(loan_simulation_model): LoanSimulation
          +get_all_by_user_id(user_id): List[LoanSimulation]
          +get_by_loan_parameters_id(loan_parameters_id): Optional[LoanSimulation]
        }

        class PaymentPeriodMySQLRepository {
          +__init__(db)
          +to_model(payment_period): PaymentPeriodModel
          +to_entity(payment_period_model): PaymentPeriod
          +get_all_by_payment_schedule_id(payment_schedule_id): List[PaymentPeriod]
        }

        class PaymentScheduleMySQLRepository {
          +__init__(db)
          +to_model(payment_schedule): PaymentScheduleModel
          +to_entity(payment_schedule_model): PaymentSchedule
          +get_by_loan_simulation_id(loan_simulation_id): Optional[PaymentSchedule]
        }
      }
    }
  }

  ' Interface layer
  package "interfaces" {
    class analytics_api {
      +calculate_payment_schedule(): PaymentScheduleResponse
      +get_all_loan_simulations_by_user_id(): LoanSimulationWrapper
      +get_loan_simulation_summary_by_id(): LoanSimulationSummaryResponse
    }
  }
}

