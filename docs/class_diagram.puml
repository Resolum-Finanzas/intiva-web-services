title Intiva Web Services Application - Class Diagram

' Shared components used across bounded contexts
package "Shared Components" #F29983 {
  package "domain" {
    package "model" {
      class BaseEntity {
        id: int
        created_at: datetime
        updated_at: datetime
      }
    }
  }

  package "infrastructure" {
    package "persistence" {
      package "repositories" {
        class BaseRepository {
          +to_entity(model): TEntity
          +to_model(entity): TModel
          +create(entity): TEntity
          +update(entity): TEntity
          +get_by_id(id): Optional[TEntity]
          +get_all(): List[TEntity]
          +delete(id): None
        }
      }

      package "model" {
        class BaseModelORM {
          id: Mapped[str]
          created_at: Mapped[datetime]
          updated_at: Mapped[datetime]
        }
      }

      package "database" {
        class db {
          +connect()
          +create_tables()
          +shutdown()
        }

        class init_db {
          +init_db()
          +get_db()
        }
      }
    }
  }
}

' Main application class
class app {
  +setup()
  +run()
}

' IAM Bounded Context
package "IAM Bounded Context" #FFEBDE {

  ' Domain layer
  package "domain" {
    package "services" {
      class UserService {
        +validate_email(email): None
        +validate_password(password): None
        +create_user(email, hashed_password): User
      }
    }

    package "model" {
      class User {
        email: str
        hashed_password: str
      }
    }
  }

  ' Application layer
  package "application" {
    class AuthenticationApplicationService {
      -user_repository: UserRepository
      -user_service: UserService
      -hashing_service: HashingService
      -token_service: TokenService
      +__init__(db)
      +sign_up(full_name, email, password): User
      +sign_in(email, password): Tuple[User, str]
    }

    class UserApplicationService {
      -user_repository: UserRepository
      +__init__(db)
      +get_user_by_email(email): Optional[User]
      +get_user_by_id(id): Optional[User]
    }
  }

  ' Infrastructure layer
  package "infrastructure" {
    package "tokens" {
      class TokenService {
        +create_access_token(data): str
        +decode_token(token): dict[str, Any]
      }
    }

    package "hashing" {
      class HashingService {
        +hash(password): str
        +verify(password, hashed_password): bool
      }
    }

    package "repositories" {
      class UserRepository {
        -user_mysql_repository: UserMySQLRepository
        +__init__(db)
        +create_user(email, hashed_password): User
        +get_by_email(email): Optional[User]
        +exists_by_email(email): bool
        +get_by_id(id): Optional[User]
      }
    }

    package "persistence" {
      package "model" {
        class UserModel {
          email: Mapped[str]
          hashed_password: Mapped[str]
        }
      }

      package "repositories" {
        class UserMySQLRepository {
          +__init__(db)
          +to_model(user): UserModel
          +to_entity(user_model): User
          +get_by_email(email): Optional[User]
          +exists_by_email(email): bool
        }
      }
    }
  }

  ' Interface layer
  package "interfaces" {
    class iam_api {
      +sign_up(): UserResponse
      +sign_in(): AuthenticatedUserResponse
      +get_user_by_email(): UserResponse
      +get_user_by_id(): UserResponse
    }
  }
}

